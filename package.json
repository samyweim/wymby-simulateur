{
  "name": "wymby-simulateur",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -b packages/types packages/config packages/engine",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b packages/types packages/config packages/engine --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
